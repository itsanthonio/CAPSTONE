{% extends 'base.html' %}

{% block title %}Live Map - {{ settings.APP_NAME }}{% endblock %}

{% block content %}
<div class="flex h-screen pt-16">
    <div class="flex-1 relative">
        
        <!-- Map Controls -->
        <div class="absolute top-4 left-4 z-20 space-y-2">
            <button id="toggle-hls-layer" class="px-4 py-2 bg-active-gold text-white rounded-lg shadow-sm hover:bg-opacity-90 transition-colors block">
                HLS Imagery
            </button>
            <button id="toggle-detection-layer" class="px-4 py-2 bg-active-gold text-white rounded-lg shadow-sm hover:bg-opacity-90 transition-colors block">
                Detections
            </button>
            <button id="toggle-concession-layer" class="px-4 py-2 bg-active-gold text-white rounded-lg shadow-sm hover:bg-opacity-90 transition-colors block">
                Legal Concessions
            </button>
            <button id="draw-aoi-btn" class="px-4 py-2 bg-sidebar-green text-white rounded-lg shadow-sm hover:bg-opacity-90 transition-colors block">
                Draw Area
            </button>
        </div>
        
        <!-- Coordinate Display -->
        <div class="absolute top-4 left-72 z-20">
            <div class="bg-white px-3 py-1 rounded-lg shadow-sm text-sm text-gray-700 border border-gray-200">
                Lat: <span id="lat-display">6.6885</span>°, Lng: <span id="lng-display">-1.6244</span>°
            </div>
        </div>
        
        <!-- Map Container -->
        <div id="live-map" class="w-full h-full bg-gray-100 z-0">
            <!-- MapLibre GL JS will initialize here -->
        </div>
        
        <!-- Scale Indicator -->
        <div class="absolute bottom-4 left-4 z-10">
            <div class="bg-white px-3 py-1 rounded shadow-sm text-sm text-gray-700">
                <span id="scale-display">5 km</span>
            </div>
        </div>
        
        <!-- Map Legend -->
        <div class="absolute bottom-4 right-4 z-20">
            <div class="bg-white rounded-lg shadow-sm p-3">
                <h4 class="text-xs font-semibold text-gray-700 mb-2">Legend</h4>
                <div class="space-y-1">
                    <div class="flex items-center text-xs">
                        <div class="w-3 h-3 bg-alert-red rounded mr-2"></div>
                        <span>Illegal Mining Detection</span>
                    </div>
                    <div class="flex items-center text-xs">
                        <div class="w-3 h-3 bg-gis-blue rounded mr-2"></div>
                        <span>Legal Concession</span>
                    </div>
                    <div class="flex items-center text-xs">
                        <div class="w-3 h-3 bg-conflict-purple rounded mr-2"></div>
                        <span>Conflict/Overlap Zone</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- HLS Metadata Display -->
        <div class="absolute top-4 right-4 z-20">
            <div class="bg-white rounded-lg shadow-sm p-3 max-w-xs">
                <h4 class="text-xs font-semibold text-gray-700 mb-1">HLS Optical Metadata</h4>
                <div class="text-xs text-gray-600 space-y-1">
                    <div>Satellite: Landsat 8/9</div>
                    <div>Date: <span id="hls-date">2024-12-10</span></div>
                    <div>Cloud Cover: <span id="cloud-cover">&lt;10%</span></div>
                    <div>Processing: Real-time</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Detection Details Panel -->
    <div class="w-80 bg-white border-l border-gray-200 flex flex-col">
        <div class="p-4 border-b border-gray-200">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 text-alert-red mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                    </svg>
                    Detection Details
                </h2>
                <span id="detection-count" class="px-2 py-1 bg-alert-red text-white text-xs font-medium rounded-full">
                    0 detections
                </span>
            </div>
        </div>
        
        <!-- AOI Scan Section -->
        <div id="aoi-scan-section" class="p-4 border-b border-gray-200 hidden">
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3">
                <h4 class="text-sm font-medium text-yellow-800 mb-2">AOI Selected</h4>
                <div class="text-xs text-yellow-700 mb-2">
                    Area: <span id="aoi-area">0.00</span> km²
                </div>
                <button id="scan-aoi-btn" class="w-full px-3 py-2 bg-active-gold text-white text-xs rounded hover:bg-opacity-90 transition-colors">
                    Scan AOI
                </button>
            </div>
        </div>
        
        <!-- Confidence Filter -->
        <div class="p-4 border-b border-gray-200">
            <h4 class="text-sm font-medium text-gray-700 mb-3">Confidence Filter</h4>
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600">Min Confidence</span>
                    <span id="confidence-value" class="text-xs font-medium text-gray-900">50%</span>
                </div>
                <input type="range" id="confidence-slider" min="0" max="100" value="50" 
                       class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
            </div>
        </div>
        
        <!-- Detection List -->
        <div class="flex-1 overflow-y-auto p-4 space-y-3" id="detection-list">
            <!-- Detections will be populated here -->
            <div class="text-center text-gray-500 text-sm py-8">
                <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                </svg>
                <p>No detections loaded</p>
                <p class="text-xs mt-1">Draw an AOI and scan to begin</p>
            </div>
        </div>
        
        <!-- Export Options -->
        <div class="p-4 border-t border-gray-200">
            <div class="grid grid-cols-2 gap-2">
                <button class="px-3 py-2 bg-gray-600 text-white text-xs rounded hover:bg-opacity-90 transition-colors">
                    Export GeoJSON
                </button>
                <button class="px-3 py-2 bg-gray-600 text-white text-xs rounded hover:bg-opacity-90 transition-colors">
                    Export CSV
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// HLS Optical Map Implementation
class HLSOpticalMap {
    constructor() {
        this.map = null;
        this.layers = {
            hls: null,
            detections: null,
            concessions: null
        };
        this.layerVisibility = {
            hls: true,
            detections: true,
            concessions: true
        };
        this.currentAOI = null;
        this.drawingMode = false;
        this.detections = [];
        this.minConfidence = 50;
        
        this.init();
    }
    
    init() {
        this.initializeMap();
        this.setupEventListeners();
        this.addMockData();
    }
    
    initializeMap() {
        // Initialize MapLibre GL JS
        this.map = new maplibregl.Map({
            container: 'live-map',
            style: 'https://api.maptiler.com/maps/streets/style.json?key=get_your_own_Op_iEsA',
            center: [-1.6244, 6.6885], // Ghana coordinates
            zoom: 10,
            attributionControl: false
        });
        
        this.map.on('load', () => {
            this.addLayers();
            this.updateCoordinateDisplay();
        });
        
        this.map.on('mousemove', (e) => {
            this.updateCoordinateDisplay(e.lngLat);
        });
    }
    
    addLayers() {
        // HLS Imagery Layer (placeholder)
        this.layers.hls = {
            'id': 'hls-imagery',
            'type': 'raster',
            'source': {
                'type': 'raster',
                'tiles': [
                    'https://tile.openstreetmap.org/{z}/{x}/{y}.png'
                ],
                'tileSize': 256
            },
            'paint': {
                'raster-opacity': 0.7
            }
        };
        
        // Detection Layer
        this.layers.detections = {
            'id': 'detections',
            'type': 'fill',
            'source': {
                'type': 'geojson',
                'data': {
                    'type': 'FeatureCollection',
                    'features': []
                }
            },
            'paint': {
                'fill-color': '#ef4444',
                'fill-opacity': 0.6
            }
        };
        
        // Legal Concessions Layer
        this.layers.concessions = {
            'id': 'concessions',
            'type': 'fill',
            'source': {
                'type': 'geojson',
                'data': {
                    'type': 'FeatureCollection',
                    'features': []
                }
            },
            'paint': {
                'fill-color': '#3b82f6',
                'fill-opacity': 0.3
            }
        };
        
        // Add layers to map
        this.map.addLayer(this.layers.hls);
        this.map.addLayer(this.layers.detections);
        this.map.addLayer(this.layers.concessions);
    }
    
    setupEventListeners() {
        // Layer toggle buttons
        document.getElementById('toggle-hls-layer').addEventListener('click', () => {
            this.toggleLayer('hls');
        });
        
        document.getElementById('toggle-detection-layer').addEventListener('click', () => {
            this.toggleLayer('detections');
        });
        
        document.getElementById('toggle-concession-layer').addEventListener('click', () => {
            this.toggleLayer('concessions');
        });
        
        // AOI drawing
        document.getElementById('draw-aoi-btn').addEventListener('click', () => {
            this.toggleDrawingMode();
        });
        
        // AOI scanning
        document.getElementById('scan-aoi-btn').addEventListener('click', () => {
            this.scanAOI();
        });
        
        // Confidence filter
        document.getElementById('confidence-slider').addEventListener('input', (e) => {
            this.updateConfidenceFilter(e.target.value);
        });
    }
    
    toggleLayer(layerName) {
        this.layerVisibility[layerName] = !this.layerVisibility[layerName];
        
        if (this.layerVisibility[layerName]) {
            this.map.setLayoutProperty(this.layers[layerName].id, 'visibility', 'visible');
        } else {
            this.map.setLayoutProperty(this.layers[layerName].id, 'visibility', 'none');
        }
    }
    
    toggleDrawingMode() {
        this.drawingMode = !this.drawingMode;
        const btn = document.getElementById('draw-aoi-btn');
        
        if (this.drawingMode) {
            btn.textContent = 'Cancel Drawing';
            btn.classList.remove('bg-sidebar-green');
            btn.classList.add('bg-alert-red');
            this.enableDrawing();
        } else {
            btn.textContent = 'Draw Area';
            btn.classList.remove('bg-alert-red');
            btn.classList.add('bg-sidebar-green');
            this.disableDrawing();
        }
    }
    
    enableDrawing() {
        // Placeholder for drawing functionality
        console.log('Drawing mode enabled');
        // In real implementation, this would enable MapLibre GL JS drawing tools
    }
    
    disableDrawing() {
        // Placeholder for disabling drawing
        console.log('Drawing mode disabled');
    }
    
    scanAOI() {
        if (!this.currentAOI) return;
        
        // Show loading state
        const scanBtn = document.getElementById('scan-aoi-btn');
        scanBtn.textContent = 'Scanning...';
        scanBtn.disabled = true;
        
        // Call HLS inference endpoint
        fetch('/analysis/run_hls_inference/', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': this.getCookie('csrftoken')
            },
            body: JSON.stringify({
                aoi: this.currentAOI
            })
        })
        .then(response => response.json())
        .then(data => {
            this.processDetections(data.detections);
            scanBtn.textContent = 'Scan AOI';
            scanBtn.disabled = false;
        })
        .catch(error => {
            console.error('Scan failed:', error);
            scanBtn.textContent = 'Scan AOI';
            scanBtn.disabled = false;
        });
    }
    
    processDetections(detections) {
        this.detections = detections;
        this.updateDetectionList();
        this.updateDetectionLayer();
        this.updateDetectionCount();
    }
    
    updateDetectionLayer() {
        const filteredDetections = this.detections.filter(d => d.confidence >= this.minConfidence);
        
        this.map.getSource('detections').setData({
            'type': 'FeatureCollection',
            'features': filteredDetections.map(d => ({
                'type': 'Feature',
                'geometry': d.geometry,
                'properties': {
                    'id': d.id,
                    'confidence': d.confidence,
                    'area': d.area
                }
            }))
        });
    }
    
    updateDetectionList() {
        const listContainer = document.getElementById('detection-list');
        const filteredDetections = this.detections.filter(d => d.confidence >= this.minConfidence);
        
        if (filteredDetections.length === 0) {
            listContainer.innerHTML = `
                <div class="text-center text-gray-500 text-sm py-8">
                    <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                    </svg>
                    <p>No detections found</p>
                    <p class="text-xs mt-1">Try lowering the confidence threshold</p>
                </div>
            `;
            return;
        }
        
        listContainer.innerHTML = filteredDetections.map(detection => `
            <div class="bg-red-50 border border-red-200 rounded-lg p-3 cursor-pointer hover:bg-red-100 transition-colors">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <div class="flex items-center mb-1">
                            <div class="w-2 h-2 bg-alert-red rounded-full mr-2"></div>
                            <h4 class="text-sm font-medium text-gray-900">Detection #${detection.id}</h4>
                        </div>
                        <p class="text-xs text-gray-600 mb-1">Area: ${detection.area.toFixed(2)} hectares</p>
                        <p class="text-xs text-gray-700">Model Prediction: ${detection.confidence.toFixed(1)}%</p>
                    </div>
                </div>
                <div class="flex space-x-2 mt-3">
                    <button class="px-3 py-1 bg-active-gold text-white text-xs rounded hover:bg-opacity-90 transition-colors">
                        View Details
                    </button>
                </div>
            </div>
        `).join('');
    }
    
    updateDetectionCount() {
        const count = this.detections.filter(d => d.confidence >= this.minConfidence).length;
        document.getElementById('detection-count').textContent = `${count} detections`;
    }
    
    updateConfidenceFilter(value) {
        this.minConfidence = parseInt(value);
        document.getElementById('confidence-value').textContent = `${value}%`;
        this.updateDetectionLayer();
        this.updateDetectionList();
        this.updateDetectionCount();
    }
    
    updateCoordinateDisplay(lngLat = null) {
        if (lngLat) {
            document.getElementById('lat-display').textContent = lngLat.lat.toFixed(4);
            document.getElementById('lng-display').textContent = lngLat.lng.toFixed(4);
        }
    }
    
    addMockData() {
        // Add mock detections for demonstration
        setTimeout(() => {
            const mockDetections = [
                {
                    id: 'D001',
                    geometry: {
                        type: 'Polygon',
                        coordinates: [[[-1.6244, 6.6885], [-1.6234, 6.6885], [-1.6234, 6.6895], [-1.6244, 6.6895], [-1.6244, 6.6885]]]
                    },
                    confidence: 94.3,
                    area: 12.5
                },
                {
                    id: 'D002',
                    geometry: {
                        type: 'Polygon',
                        coordinates: [[[-1.6254, 6.6875], [-1.6244, 6.6875], [-1.6244, 6.6885], [-1.6254, 6.6885], [-1.6254, 6.6875]]]
                    },
                    confidence: 87.1,
                    area: 8.3
                }
            ];
            
            this.processDetections(mockDetections);
        }, 1000);
    }
    
    getCookie(name) {
        let cookieValue = null;
        if (document.cookie && document.cookie !== '') {
            const cookies = document.cookie.split(';');
            for (let i = 0; i < cookies.length; i++) {
                const cookie = cookies[i].trim();
                if (cookie.substring(0, name.length + 1) === (name + '=')) {
                    cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
                    break;
                }
            }
        }
        return cookieValue;
    }
}

// Initialize map when DOM is loaded
document.addEventListener('DOMContentLoaded', function() {
    new HLSOpticalMap();
});
</script>
{% endblock %}